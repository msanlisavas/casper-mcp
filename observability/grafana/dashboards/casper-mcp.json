{
  "uid": "casper-mcp",
  "title": "Casper MCP — Observability",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "stat", "title": "Total tool calls", "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(casper_mcp_tool_calls_total)" } ]
    },
    {
      "type": "piechart", "title": "Calls by status (ok / error)", "id": 2,
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (casper_mcp_tool_calls_total)", "legendFormat": "{{status}}", "instant": true } ]
    },
    {
      "type": "timeseries", "title": "Call rate by tool (per sec, 1m)", "id": 3,
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (tool) (rate(casper_mcp_tool_calls_total[1m]))", "legendFormat": "{{tool}}" } ]
    },
    {
      "type": "timeseries", "title": "Success vs error rate", "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (rate(casper_mcp_tool_calls_total[1m]))", "legendFormat": "{{status}}" } ]
    },
    {
      "type": "timeseries", "title": "p95 tool latency (ms) by tool", "id": 5,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(casper_mcp_tool_duration_milliseconds_bucket[5m])))", "legendFormat": "{{tool}}" } ]
    },
    {
      "type": "logs", "title": "Tool call logs (tool / status / duration / tenant / correlation_id)", "id": 6,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true },
      "targets": [ { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{service_name=\"casper-mcp\"}", "queryType": "range" } ]
    },
    {
      "type": "logs", "title": "Errors only", "id": 7,
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true },
      "targets": [ { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{service_name=\"casper-mcp\"} |= \"status=error\"", "queryType": "range" } ]
    }
  ]
}
